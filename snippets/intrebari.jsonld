    {
      "@type": "FAQPage",
      "@id": "https://ecbtax.com/intrebari.html#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Ce servicii oferă ECBTAX?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ECBTAX oferă servicii de contabilitate, fiscalitate, salarizare, administrare HR, REVISAL, consultanță fiscală, suport ANAF, e-Factura, SAF-T și servicii financiare pentru firme, PFA, SRL și ONG."
          }
        },
        {
          "@type": "Question",
          "name": "Pentru cine sunt potrivite serviciile ECBTAX?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Serviciile ECBTAX sunt potrivite pentru SRL-uri, PFA-uri, ONG-uri, startup-uri, firme de servicii, e-commerce, companii cu salariați și organizații care au nevoie de contabilitate clară, fiscalitate corectă și suport administrativ."
          }
        },
        {
          "@type": "Question",
          "name": "ECBTAX poate prelua contabilitatea de la o altă firmă?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Da. ECBTAX poate analiza situația existentă, poate cere documentele necesare, poate verifica soldurile și poate organiza preluarea contabilității astfel încât tranziția să fie clară și controlată."
          }
        },
        {
          "@type": "Question",
          "name": "Oferă ECBTAX suport pentru ANAF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Da. ECBTAX oferă suport pentru relația cu ANAF, declarații fiscale, clarificări, verificări, e-Factura, SAF-T și alte obligații fiscale aplicabile firmelor din România."
          }
        },
        {
          "@type": "Question",
          "name": "ECBTAX oferă servicii de salarizare și REVISAL?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Da. ECBTAX oferă salarizare, administrare contracte de muncă, state de plată, declarații aferente salariilor și administrare REVISAL pentru companii cu angajați."
          }
        },
        {
          "@type": "Question",
          "name": "Ce documente sunt necesare pentru începerea colaborării?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "În general sunt necesare documentele firmei, balanțele contabile, declarațiile depuse, extrasele bancare, facturile, contractele și situațiile salariale. Lista exactă depinde de tipul firmei și de stadiul contabilității existente."
          }
        },
        {
          "@type": "Question",
          "name": "ECBTAX lucrează cu firme din afara Bucureștiului?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Da. ECBTAX poate lucra cu firme din România și cu structuri care operează digital, folosind documente electronice, comunicare online și fluxuri administrative clare."
          }
        },
        {
          "@type": "Question",
          "name": "Cum se stabilește prețul serviciilor ECBTAX?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Prețul depinde de volumul de documente, numărul de angajați, complexitatea fiscală, tipul firmei, obligațiile declarative și nivelul de suport necesar. Pentru o ofertă corectă este necesară o analiză inițială."
          }
        },
        {
          "@type": "Question",
          "name": "Cine coordonează activitatea profesională ECBTAX?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Activitatea ECBTAX este coordonată de Elena Roxana Deak, CEO și fondator, cu acreditări profesionale FCCA, CPA și CCF și experiență în contabilitate, fiscalitate, macroeconomie și sisteme financiare."
          }
        },
        {
          "@type": "Question",
          "name": "Ce legătură are ECBTAX cu AiVenture și 5thelement.ai?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ECBTAX rămâne firma de contabilitate, fiscalitate și HR. AiVenture și 5thelement.ai sunt parteneri tehnologici pentru stratul AI Delivery Infrastructure, folosit pentru structurarea informației, semnale AI, verificabilitate și pregătire pentru sisteme AI."
          }
        }
      ]
    }
  ]
}